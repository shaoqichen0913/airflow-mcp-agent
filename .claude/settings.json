{
  "mcpServers": {
    "airflow": {
      "command": "uvx",
      "args": ["mcp-server-apache-airflow"],
      "env": {
        "AIRFLOW_HOST": "http://localhost:8080",
        "AIRFLOW_USERNAME": "admin",
        "AIRFLOW_PASSWORD": "admin"
      }
    }
  },
  "permissions": {
    "allow": [
      "mcp__airflow__post_dag_run",
      "mcp__airflow__get_dag_run",
      "mcp__airflow__get_dag_runs",
      "mcp__airflow__get_dag_runs_batch",
      "mcp__airflow__get_dags",
      "mcp__airflow__get_dag",
      "mcp__airflow__get_task_instances",
      "mcp__airflow__get_task_instance",
      "mcp__airflow__get_mapped_task_instances",
      "mcp__airflow__get_log",
      "mcp__airflow__get_xcom_entries",
      "mcp__airflow__get_xcom_entry"
    ]
  }
}
